# Flask
SECRET_KEY=change-this-in-production

# Database
# Use Postgres on Render e.g. postgres://... (we'll normalize to postgresql://)
DATABASE_URL=sqlite:///chat.db

# Uploads
UPLOAD_FOLDER=/data/uploads
ALLOWED_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png,txt

# CORS (keep * for now; tighten later)
CORS_ORIGINS=*

# Flask-SocketIO async mode
ASYNC_MODE=eventlet

# Max upload size (MB)
MAX_UPLOAD_MB=20
